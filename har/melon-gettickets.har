            "mimeType": "text/javascript",
            "text": "{\n  \"browserCheckMessage\" : {\n    \"crossBrowserMessage\" : \"Melon Ticket service can be used seamlessly in Internet Explorer 10 or later. Please update your Explorer or by using the Chrome browser.\",\n    \"mobileBrowserMessage\" : \"This site only supports PC web browser\"\n  },\n  \"systemMessage\" : {\n    \"systemError\":\"System Error. Please ask melonticket.\",\n    \"systemErrorType1\":\"Please try later.\",\n    \"systemErrorType2\":\"This is not the right approach.\",\n    \"systemErrorType3\":\"Please, Try again.\"\n\n  },\n  \"preSaleReservationMessage\" : {\n    \"idConfirm\" : \"Your ID has been verified.\",\n    \"message1\" : \"You do not have permission to book this show now. During pre-sales, only approved customers have access to booking page.\"\n  },\n  \"selectedTimeScheduleMessage\" : {\n    \"selectedMessage\" : \"Please select date/time.\"\n  },\n  \"saleSeatClosedMessage\" : {\n    \"seatMessage\" : \"The sale has been closed.\"\n  },\n  \"reservationTimeCheckMessage\" : {\n    \"timeCheckMessage\" : \"Ticket cancellations are not allowed after 5pm one day before the event (after 11am on Saturdays) or on the date of the event date. Confirm Booking?\"\n  },\n  \"passportVerifiedMessage\" : {\n    \"T9502Message\" : \"You have exceeded 5 verification attempts. Please try again after 1 hour.\",\n    \"T9503Message\" : \"Too many verification attempts. Please try again after 1 hour.\",\n    \"T9504Message\" : \"Too many verification attempts. Please try again after 24 hours.\",\n    \"T9505Message\" : \"Verification is unavailable due to maintenance. Please try again later.\"\n  }\n\n}"
